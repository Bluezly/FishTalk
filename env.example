# your bot's token from the Discord Developer Portal
DISCORD_TOKEN=

# api key from fish.audio, used for text-to-speech
FISH_API_KEY=

# api key from Google AI Studio, used as the chat brain
GEMINI_API_KEY=

# which service to use for speech-to-text: groq or elevenlabs
ASR_PROVIDER=groq

# only needed if ASR_PROVIDER=groq
GROQ_API_KEY=

# only needed if ASR_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=

# language code for transcription, e.g. en, ar, es
ASR_LANGUAGE=en

# male or female, just changes how the persona refers to itself
ASSISTANT_GENDER=male

# fish audio voice id to use, leave blank for the default voice
FISH_VOICE_ID=

# playback speed for the tts, 1 is normal speed
TTS_SPEED=1

# output volume multiplier, 1 is normal, 2 is double
TTS_VOLUME=2
